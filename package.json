{
  "name": "coldmailai-backend",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:gateway": "npm --workspace @coldmailai/gateway run dev",
    "dev:auth": "npm --workspace @coldmailai/auth-service run dev",
    "dev:users": "npm --workspace @coldmailai/user-service run dev",
    "dev:usage": "npm --workspace @coldmailai/usage-service run dev",
    "dev:ai": "npm --workspace @coldmailai/ai-service run dev",
    "dev:emails": "npm --workspace @coldmailai/email-service run dev",
    "dev:billing": "npm --workspace @coldmailai/billing-service run dev",
    "dev:notifications": "npm --workspace @coldmailai/notification-service run dev",
    "check": "node scripts/check.mjs",
    "assign-plan": "node scripts/assign-plan.mjs"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/svelte-query": "^5.90.2",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "axios": "^1.17.0",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "postcss": "^8.5.15",
    "react-router-dom": "^6.30.4",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "vite": "^8.0.16",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
